# --- Data ---------------------------------------------------------------------
# Raw provider dumps (huge, re-pullable) are never committed; the curated reference CSVs are.
data/raw/*
!data/raw/.gitkeep
!data/reference/

# Cache: gitignored by default, EXCEPT a committed "frozen analysis snapshot" — the derived data
# needed to regenerate the published site/report/figures and verify the headline OFFLINE (a re-pull
# would drift, so this snapshot is the only path to the exact published numbers). The bulky,
# re-pullable raw caches + resumable shard directories stay out (see the explicit re-excludes below).
data/cache/*
!data/cache/.gitkeep
# posteriors
!data/cache/*.nc
# model + feature outputs, frozen attention/news signals (allowlisted individually)
!data/cache/model_features.parquet
!data/cache/merit_features.parquet
!data/cache/tier2_pool.parquet
!data/cache/team_success.parquet
!data/cache/club_importance_features.parquet
!data/cache/hperp_pageviews.parquet
!data/cache/hperp_gdelt.parquet
!data/cache/gdelt_attention_pool.parquet
!data/cache/pageview_attention.parquet
!data/cache/pageview_attention_pool.parquet
!data/cache/robustness_panel.parquet
!data/cache/prior_sensitivity.parquet
!data/cache/statsbomb_tournament.parquet
!data/cache/awards_results.parquet
!data/cache/hype_watch_2026.parquet
!data/cache/pageviews_all_lang_daily.parquet
!data/cache/gdelt_volume_daily.parquet
!data/cache/understat_2526_seasons.parquet
!data/cache/pageviews_2026_hypewatch.parquet
# Bulky re-pullable raw caches: out (only needed for a `--refresh` rebuild, not the published regen).
# (`data/cache/*` already ignores everything else, incl. the resumable shard subdirectories.)

# Python
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/

# Notebooks
.ipynb_checkpoints/

# Quarto / rendered HTML. The local working render (report/ballon-dor.html) is a build artifact; the
# self-contained copy bundled for the live site (site/report/ballon-dor.html) IS committed (Pages
# serves it). The public site's own source is committed too.
.quarto/
/_site/
*.html
!site/index.html
!site/report/ballon-dor.html

# Build artifacts: report figure PNGs are regenerated by `run.py report` (the report embeds
# interactive plotly, not these), so they're not committed.
report/figures/*.png
!report/figures/.gitkeep

# Editor / workspace
*.code-workspace

# OS / editor
.DS_Store
Thumbs.db

# Design source artifact (Claude design-canvas export) — not needed at runtime
design.zip
